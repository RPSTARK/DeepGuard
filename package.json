{
  "name": "deepguard",
  "displayName": "DeepGuard — AI Dependency Guardian",
  "description": "Detect, verify, and secure Python and JavaScript dependencies before you install them. Typosquat protection, CVE scanning, malware and secret detection.",
  "version": "0.5.0",
  "publisher": "vulncraft",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Other"
  ],
  "keywords": [
    "python",
    "dependencies",
    "security",
    "typosquatting",
    "supply chain",
    "pip"
  ],
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_GITHUB_USERNAME/deepguard-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/YOUR_GITHUB_USERNAME/deepguard-vscode/issues"
  },
  "homepage": "https://github.com/YOUR_GITHUB_USERNAME/deepguard-vscode#readme",
  "galleryBanner": {
    "color": "#0d1117",
    "theme": "dark"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:python",
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onStartupFinished",
    "workspaceContains:**/*.py",
    "workspaceContains:**/package.json"
  ],
  "contributes": {
    "commands": [
      {
        "command": "deepguard.analyzeFile",
        "title": "DeepGuard: Analyze Dependencies in File",
        "icon": "$(shield)"
      },
      {
        "command": "deepguard.analyzeSelection",
        "title": "DeepGuard: Analyze Pasted Code (Selection)"
      },
      {
        "command": "deepguard.analyzeProject",
        "title": "DeepGuard: Analyze Whole Project"
      },
      {
        "command": "deepguard.generateRequirements",
        "title": "DeepGuard: Generate requirements.txt"
      },
      {
        "command": "deepguard.createVenv",
        "title": "DeepGuard: Create Virtual Environment"
      },
      {
        "command": "deepguard.generateSBOM",
        "title": "DeepGuard: Generate SBOM (CycloneDX)"
      },
      {
        "command": "deepguard.bootstrapProject",
        "title": "DeepGuard: Bootstrap Project (scaffold files)"
      },
      {
        "command": "deepguard.setupProject",
        "title": "DeepGuard: Set Up Project (scan all + venv + install)",
        "icon": "$(rocket)"
      },
      {
        "command": "deepguard.scanPackage",
        "title": "DeepGuard: Scan a Package for Malicious Install Code"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "resourceLangId == python",
          "command": "deepguard.analyzeFile",
          "group": "navigation"
        },
        {
          "when": "resourceLangId == python",
          "command": "deepguard.setupProject",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "when": "resourceLangId == python",
          "command": "deepguard.analyzeFile",
          "group": "deepguard"
        },
        {
          "when": "editorHasSelection && resourceLangId == python",
          "command": "deepguard.analyzeSelection",
          "group": "deepguard"
        }
      ]
    },
    "configuration": {
      "title": "DeepGuard",
      "properties": {
        "deepguard.analyzeOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run dependency + security analysis automatically when a Python file is saved."
        },
        "deepguard.enableCveScan": {
          "type": "boolean",
          "default": true,
          "description": "Query OSV.dev for known vulnerabilities in detected packages (requires network access)."
        },
        "deepguard.enableSecretScan": {
          "type": "boolean",
          "default": true,
          "description": "Scan analyzed code for hardcoded secrets (API keys, tokens)."
        },
        "deepguard.enableMalwareScan": {
          "type": "boolean",
          "default": true,
          "description": "Before installing, download and scan each package's source distribution (setup.py) for malicious install-time code, and block high-risk packages."
        },
        "deepguard.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Path to the Python interpreter. Leave empty to auto-detect (uses the Python extension's selected interpreter when available)."
        },
        "deepguard.useVirtualEnv": {
          "type": "string",
          "enum": [
            "ask",
            "always",
            "never"
          ],
          "enumDescriptions": [
            "Ask each time whether to create/use a .venv when installing Python packages.",
            "Always install Python packages into the project's .venv, creating it if needed.",
            "Never create a .venv automatically — install into the selected interpreter. Use the 'Create Virtual Environment' command when you want one explicitly."
          ],
          "default": "ask",
          "description": "How DeepGuard handles virtual environments for Python installs. JavaScript/npm projects never use a virtual environment."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "tsc -p ./",
    "lint": "tsc --noEmit -p ./",
    "test": "tsc -p ./ && node --test \"dist/test/**/*.test.js\"",
    "publish:patch": "vsce publish patch",
    "publish:minor": "vsce publish minor",
    "publish:major": "vsce publish major"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
